<Window x:Class="Prog_6221_Part3_PoE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberGuard AI" Height="700" Width="650"
        Background="#0A0E27" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1E2547"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A3F7A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00D9FF"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#151B3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A3F7A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#151B3D" BorderBrush="#00D9FF" BorderThickness="0,0,0,2" Padding="15">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="50" Height="50" CornerRadius="25" Background="#00D9FF" Margin="0,0,15,0">
                    <TextBlock Text="AI" Foreground="Black" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="CyberGuard AI" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Cybersecurity Awareness System" Foreground="#8A92B2" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Background="#0A0E27" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#151B3D"/>
                    <Setter Property="Foreground" Value="#8A92B2"/>
                    <Setter Property="Padding" Value="20,10"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#00D9FF"/>
                            <Setter Property="Foreground" Value="Black"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- Chat Tab with Input at Bottom -->
            <TabItem Header="Chat">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="70"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#0F1428" Margin="10" CornerRadius="5">
                        <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" Padding="15">
                            <StackPanel x:Name="ChatPanel"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Chat Input Area -->
                    <Border Grid.Row="1" Background="#151B3D" BorderBrush="#00D9FF" BorderThickness="0,1,0,0" Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="UserInputTextBox" Grid.Column="0" Height="40" FontSize="14" Foreground="White" 
                                     Background="#0A0E27" BorderBrush="#2A3F7A" BorderThickness="1" Padding="10,0" 
                                     VerticalContentAlignment="Center" KeyDown="UserInputTextBox_KeyDown"/>
                            <Button Grid.Column="1" Content="Send" Height="40" Margin="10,0,0,0" 
                                    Background="#00D9FF" Foreground="Black" FontWeight="Bold" Click="SendButton_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Tasks">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#151B3D" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBox x:Name="TxtTaskTitle" Height="40" Margin="0,0,0,10" Text="Task Title"/>
                            <TextBox x:Name="TxtTaskDesc" Height="70" Margin="0,0,0,10" TextWrapping="Wrap" Text="Description"/>
                            <TextBox x:Name="TxtTaskReminder" Height="40" Margin="0,0,0,10" Text="Reminder (optional)"/>
                            <Button Content="Add Task" Click="BtnAddTask_Click" Height="40" FontSize="14" Background="#00D9FF" Foreground="Black"/>
                        </StackPanel>
                    </Border>

                    <ListBox x:Name="TaskListBox" Grid.Row="1" Background="#151B3D" Foreground="White" 
                             BorderBrush="#2A3F7A" FontSize="14" Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Mark Complete" Click="BtnCompleteTask_Click" Width="140" Height="40" Margin="0,0,10,0" Background="#00FF88" Foreground="Black"/>
                        <Button Content="Delete" Click="BtnDeleteTask_Click" Width="100" Height="40" Background="#FF4757" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Quiz">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#151B3D" CornerRadius="5" Padding="15" Margin="0,0,0,20">
                        <TextBlock x:Name="TxtQuizScore" Text="Score: 0 / 10" Foreground="#00D9FF" 
                                   FontSize="20" FontWeight="Bold" TextAlignment="Center"/>
                    </Border>
                    
                    <Border Grid.Row="1" Background="#151B3D" CornerRadius="5" Padding="20">
                        <StackPanel>
                            <TextBlock x:Name="TxtQuizQuestion" Text="Click 'Start Quiz' to begin." 
                                       Foreground="White" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,20"/>
                            <StackPanel x:Name="QuizOptionsPanel"/>
                            <Border x:Name="FeedbackBorder" Background="#1E2547" CornerRadius="5" Padding="15" Margin="0,20,0,0">
                                <TextBlock x:Name="TxtQuizFeedback" Foreground="#FFD93D" FontSize="14" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button x:Name="BtnStartQuiz" Content="Start Quiz" Click="BtnStartQuiz_Click" Width="120" Height="45" Margin="0,0,10,0" Background="#00D9FF" Foreground="Black"/>
                        <Button x:Name="BtnSubmitAnswer" Content="Submit" Click="BtnSubmitAnswer_Click" Width="100" Height="45" Margin="0,0,10,0" Background="#00FF88" Foreground="Black" IsEnabled="False"/>
                        <Button x:Name="BtnNextQuestion" Content="Next" Click="BtnNextQuestion_Click" Width="100" Height="45" Background="#FFD93D" Foreground="Black" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Activity Log">
                <Grid Margin="20">
                    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Border Background="#151B3D" CornerRadius="5" Padding="15">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="TxtActivityLog" Foreground="White" FontSize="14" TextWrapping="Wrap" LineHeight="25"/>
                        </ScrollViewer>
                    </Border>
                    <Button x:Name="BtnShowMoreLog" Grid.Row="1" Content="Show Full History" Click="BtnShowMoreLog_Click" Margin="0,15,0,0" Height="40" Visibility="Collapsed"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
